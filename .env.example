# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/chat_db

# ── Standalone (local auth) ──────────────────────────────
AUTH_MODE=local
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ── SSO / OIDC (Keycloak etc.) ───────────────────────────
# AUTH_MODE=oidc
# OIDC_JWKS_URL=https://keycloak.example.com/realms/auranest/protocol/openid-connect/certs
# OIDC_ISSUER=https://keycloak.example.com/realms/auranest
# OIDC_AUDIENCE=account

# Ports (Chat app: 3040 / 3041)
# PORT        — NestJS reads this for the local dev server
# BACKEND_PORT — Docker Compose host port mapping (container always listens on PORT)
PORT=3040
BACKEND_PORT=3040
FRONTEND_PORT=3041

# Seed user (local auth only — used by pnpm -C backend prisma:seed)
SEED_USER_EMAIL=admin@example.com
SEED_USER_PASSWORD=password123
SEED_USER_NAME=Admin
